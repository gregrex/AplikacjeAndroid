@inherits LayoutComponentBase
@implements IDisposable
@inject ProjectThemeService ThemeService
@inject ProjectContextService ProjectContext

<div class="app-shell" style="@_themeStyle">
    <div class="topbar">
        <div>@_brandName</div>
        <small>@ProjectContext.CurrentProjectId</small>
    </div>
    <main class="content">
        @Body
    </main>
</div>

@code {
    private string _brandName = "AppFactory Mobile";
    private string _themeStyle = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        ProjectContext.ProjectChanged += OnProjectChanged;
        await LoadThemeAsync(ProjectContext.CurrentProjectId);
    }

    private async void OnProjectChanged(string projectId)
    {
        await LoadThemeAsync(projectId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadThemeAsync(string projectId)
    {
        var theme = await ThemeService.LoadThemeAsync(projectId);
        _brandName = string.IsNullOrWhiteSpace(theme.BrandName) ? "AppFactory Mobile" : theme.BrandName;
        _themeStyle = BuildStyle(theme);
    }

    private static string BuildStyle(ThemeDefinition theme)
    {
        return string.Join(" ", new[]
        {
            $"--primary:{theme.PrimaryColor};",
            $"--secondary:{theme.SecondaryColor};",
            $"--accent:{theme.AccentColor};",
            $"--bg:{theme.BackgroundColor};",
            $"--card:{theme.SurfaceColor};",
            $"--text:{theme.TextColor};",
            $"--muted:{theme.MutedTextColor};",
            $"--danger:{theme.DangerColor};"
        });
    }

    public void Dispose()
    {
        ProjectContext.ProjectChanged -= OnProjectChanged;
    }
}
