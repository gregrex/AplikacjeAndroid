@page "/result/{CategoryId}/{FreeResultId}/{PremiumResultId}"
@inject ProjectDataService ProjectData
@inject ResultService ResultService
@inject MockAdService Ads
@inject HistoryService History
@inject FavoritesService Favorites
@inject LanguageService Language
@inject ProjectContextService ProjectContext
@inject ProjectUiProfileService UiProfiles
@inject ResultNavigationStateService ResultNavigationState
@inject NavigationManager Nav

<section class="hero-card">
    <div class="hero-icon" aria-hidden="true">@_uiProfile.Icon</div>
    <p class="result-kicker">Krok 3 · @_uiProfile.Badge</p>
    <h1>@_uiProfile.ResultHeading</h1>
    <p>Wynik został dobrany lokalnie na podstawie odpowiedzi i reguł projektu.</p>
</section>

@if (_freeResult is null)
{
    <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">!</div>
        <h2>Nie udało się wczytać wyniku</h2>
        <p class="muted">@_uiProfile.EmptyStateText</p>
        <a class="button" href="/quiz/@CategoryId">Wróć do quizu</a>
    </div>
}
else
{
    <ProjectResultView ProjectId="@ProjectContext.CurrentProjectId" Result="@_freeResult" ShowPremiumBlocks="false" />

    @if (_matchInfo.HasAnyInfo)
    {
        <section class="card">
            <p class="result-kicker">Przejrzyste dopasowanie</p>
            <h3>Dlaczego taki wynik?</h3>
            <p>@(!string.IsNullOrWhiteSpace(_matchInfo.Reason) ? _matchInfo.Reason : "Wynik został dobrany na podstawie odpowiedzi z formularza i najlepiej dopasowanej reguły.")</p>

            <div class="metric-grid">
                <div class="metric">
                    <span class="muted small">Reguła</span>
                    <strong>@_matchInfo.RuleId</strong>
                </div>
                <div class="metric">
                    <span class="muted small">Punkty</span>
                    <strong>@_matchInfo.Score</strong>
                </div>
                <div class="metric">
                    <span class="muted small">Język</span>
                    <strong>@_loadedResultLanguage.ToUpperInvariant()</strong>
                </div>
            </div>

            @if (_matchInfo.MatchedConditions.Count > 0)
            {
                <h4>Dopasowane odpowiedzi</h4>
                <div class="chip-row">
                    @foreach (var condition in _matchInfo.MatchedConditions)
                    {
                        <span class="chip">@condition</span>
                    }
                </div>
            }
        </section>
    }

    @if (!_premiumUnlocked)
    {
        <section class="card">
            <p class="result-kicker">Pełna wersja</p>
            <h3>Więcej kroków i materiałów</h3>
            <p class="muted">Odblokowanie pokazuje pełną instrukcję, potrzebne rzeczy, czego unikać i alternatywne rekomendacje.</p>
            <button class="button secondary block" @onclick="UnlockPremium">@_uiProfile.PrimaryActionLabel</button>
        </section>
    }
    else if (_premiumResult is not null)
    {
        <ProjectResultView ProjectId="@ProjectContext.CurrentProjectId" Result="@_premiumResult" ShowPremiumBlocks="true" />

        @if (_alternativeResults.Count > 0)
        {
            <section class="card">
                <p class="result-kicker">Inne dopasowania</p>
                <h3>Alternatywne rekomendacje</h3>
                <p class="muted">Możesz zmienić pełną rekomendację bez ponownego przechodzenia quizu.</p>
                <div class="project-grid">
                    @foreach (var alternative in _alternativeResults)
                    {
                        <article class="project-card">
                            <div class="project-icon" aria-hidden="true">↗</div>
                            <h3>@alternative.Title</h3>
                            <p>@alternative.Summary</p>
                            @if (_premiumResult.Id == alternative.Id)
                            {
                                <span class="status-success">Aktualnie wybrana</span>
                            }
                            else
                            {
                                <button class="button ghost" @onclick="() => SelectAlternative(alternative.Id)">Wybierz alternatywę</button>
                            }
                        </article>
                    }
                </div>
            </section>
        }
    }

    <section class="card">
        <p class="result-kicker">Dalsze akcje</p>
        <div class="action-grid">
            <button class="button" @onclick="AddFavorite">@_uiProfile.SecondaryActionLabel</button>
            <button class="button ghost" @onclick="BackToQuiz">Wróć do quizu</button>
            <a class="button ghost" href="/history">Otwórz historię</a>
            <a class="button ghost" href="/favorites">Otwórz ulubione</a>
        </div>
        @if (!string.IsNullOrWhiteSpace(_actionStatus))
        {
            <p class="status-success">@_actionStatus</p>
        }
    </section>
}

@code {
    [Parameter] public string CategoryId { get; set; } = string.Empty;
    [Parameter] public string FreeResultId { get; set; } = string.Empty;
    [Parameter] public string PremiumResultId { get; set; } = string.Empty;

    private ResultDefinition? _freeResult;
    private ResultDefinition? _premiumResult;
    private readonly List<ResultDefinition> _alternativeResults = new();
    private bool _premiumUnlocked;
    private string _loadedResultLanguage = "pl";
    private string _actionStatus = string.Empty;
    private ProjectUiProfile _uiProfile = new();
    private MatchInfo _matchInfo = new();

    protected override async Task OnInitializedAsync()
    {
        _uiProfile = UiProfiles.GetProfile(ProjectContext.CurrentProjectId);
        _matchInfo = ResultNavigationState.GetOrDefault(ProjectContext.CurrentProjectId, CategoryId, FreeResultId, PremiumResultId);
        if (!_matchInfo.HasAnyInfo)
        {
            _matchInfo = MatchInfoParser.Parse(Nav.Uri);
        }

        var availableResultLanguages = new[] { "pl", "en", "uk" };
        _loadedResultLanguage = Language.GetResultLanguageWithFallback(availableResultLanguages);

        var results = await ProjectData.LoadResultsAsync(ProjectContext.CurrentProjectId, _loadedResultLanguage);
        _freeResult = ResultService.FindResult(results, FreeResultId);
        _premiumResult = ResultService.FindResult(results, PremiumResultId);

        foreach (var alternativeId in _matchInfo.AlternativePremiumResultIds)
        {
            var alternative = ResultService.FindResult(results, alternativeId);
            if (alternative is not null && alternative.Id != PremiumResultId)
            {
                _alternativeResults.Add(alternative);
            }
        }

        await History.AddAsync(new HistoryEntry
        {
            ProjectId = ProjectContext.CurrentProjectId,
            CategoryId = CategoryId,
            ResultId = FreeResultId,
            FreeResultId = FreeResultId,
            PremiumResultId = PremiumResultId
        });
    }

    private async Task UnlockPremium()
    {
        _premiumUnlocked = await Ads.ShowRewardedAsync("result_full_instruction");
        _actionStatus = _premiumUnlocked ? "Pełna rekomendacja została odblokowana." : "Nie udało się odblokować pełnej rekomendacji.";
    }

    private void SelectAlternative(string resultId)
    {
        var alternative = _alternativeResults.FirstOrDefault(x => x.Id == resultId);
        if (alternative is not null)
        {
            _premiumResult = alternative;
            _actionStatus = $"Wybrano alternatywę: {alternative.Title}.";
        }
    }

    private async Task AddFavorite()
    {
        var selectedPremiumId = _premiumUnlocked ? _premiumResult?.Id ?? PremiumResultId : PremiumResultId;
        var selectedResultId = _premiumUnlocked ? selectedPremiumId : FreeResultId;

        await Favorites.AddAsync(new FavoriteEntry
        {
            ProjectId = ProjectContext.CurrentProjectId,
            CategoryId = CategoryId,
            ResultId = selectedResultId,
            FreeResultId = FreeResultId,
            PremiumResultId = selectedPremiumId
        });

        _actionStatus = "Wynik zapisano w ulubionych.";
    }

    private void BackToQuiz()
    {
        Nav.NavigateTo($"/quiz/{CategoryId}");
    }
}
