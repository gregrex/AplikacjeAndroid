@page "/categories"
@inject ProjectDataService ProjectData
@inject ProjectContextService ProjectContext
@inject ImageAnalysisPolicyService ImagePolicies
@inject AudioAnalysisPolicyService AudioPolicies

<h1>Wybierz kategorię</h1>
<p class="muted">Projekt: @ProjectContext.CurrentProjectId</p>

@if (_imagePolicy.IsEnabled)
{
    <section class="card">
        <p class="result-kicker">Local AI image</p>
        <h3>Rozpoznawanie obrazu lokalnie</h3>
        <p>Ten projekt może korzystać z opcjonalnej analizy zdjęcia. Wynik jest podpowiedzią do formularza i wymaga ręcznego potwierdzenia.</p>
        <p class="muted">Formaty: @string.Join(", ", _imagePolicy.AcceptedContentTypes) | Limit: @(_imagePolicy.MaxSizeBytes / 1024 / 1024) MB</p>
        @if (_imagePolicy.IsSafetySensitive)
        {
            <p class="muted">Uwaga: projekt wymaga ostrożności. Zdjęcie nie zastępuje oceny ryzyka.</p>
        }
    </section>
}

@if (_audioPolicy.IsEnabled)
{
    <section class="card">
        <p class="result-kicker">Local AI audio</p>
        <h3>Rozpoznawanie dźwięku lokalnie</h3>
        <p>Ten projekt może korzystać z opcjonalnej analizy nagrania. Wynik jest podpowiedzią do formularza i wymaga ręcznego potwierdzenia.</p>
        <p class="muted">Formaty: @string.Join(", ", _audioPolicy.AcceptedContentTypes) | Limit: @(_audioPolicy.MaxSizeBytes / 1024 / 1024) MB | Czas: @_audioPolicy.MaxDuration.TotalSeconds s</p>
        @if (_audioPolicy.IsSafetySensitive)
        {
            <p class="muted">Uwaga: projekt wymaga ostrożności. Nagranie nie zastępuje oceny ryzyka.</p>
        }
    </section>
}

@if (_categories.Count == 0)
{
    <div class="card">Ładowanie kategorii...</div>
}
else
{
    @foreach (var category in _categories)
    {
        <div class="card">
            <h3>@category.Id</h3>
            <p class="muted">@category.NameKey</p>
            <a class="button" href="/quiz/@category.Id">Wybierz</a>
        </div>
    }
}

@code {
    private List<CategoryDefinition> _categories = new();
    private ImageAnalysisProjectPolicy _imagePolicy = new();
    private AudioAnalysisProjectPolicy _audioPolicy = new();

    protected override async Task OnInitializedAsync()
    {
        _imagePolicy = ImagePolicies.GetPolicy(ProjectContext.CurrentProjectId);
        _audioPolicy = AudioPolicies.GetPolicy(ProjectContext.CurrentProjectId);
        _categories = await ProjectData.LoadCategoriesAsync(ProjectContext.CurrentProjectId);
    }
}
