@page "/categories"
@inject ProjectDataService ProjectData
@inject ProjectContextService ProjectContext
@inject ProjectUiProfileService UiProfiles

@{
    var profile = UiProfiles.GetProfile(ProjectContext.CurrentProjectId);
}

<section class="hero-card">
    <div class="hero-icon" aria-hidden="true">@profile.Icon</div>
    <p class="result-kicker">@profile.Badge</p>
    <h1>@profile.HeroTitle</h1>
    <p>@profile.HeroDescription</p>
</section>

@if (!string.IsNullOrWhiteSpace(profile.ToolKind))
{
    <section class="tool-card">
        <div class="section-heading">
            <div>
                <p class="result-kicker">Dodatkowe narzędzia</p>
                <h3>Licznik i notatki projektu</h3>
            </div>
            <span aria-hidden="true">🧰</span>
        </div>
        <p class="muted">Stan jest zapisywany lokalnie i pozostaje po ponownym uruchomieniu aplikacji.</p>
        <a class="button" href="/tools">Otwórz narzędzia</a>
    </section>
}

<LocalAiPanel />

<div class="section-heading">
    <div>
        <p class="result-kicker">Krok 1</p>
        <h2>@profile.CategoryHeading</h2>
    </div>
    <span class="muted small">@_categories.Count opcji</span>
</div>

@if (_categories.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">…</div>
        <h3>Ładowanie kategorii</h3>
        <p class="muted">Dane projektu są odczytywane lokalnie.</p>
    </div>
}
else
{
    <div class="category-grid">
        @for (var index = 0; index < _categories.Count; index++)
        {
            var category = _categories[index];
            <article class="project-card">
                <div class="category-icon" aria-hidden="true">@GetCategoryIcon(index)</div>
                <p class="result-kicker">Temat @(index + 1)</p>
                <h3>@category.NameKey</h3>
                <p class="muted small">Identyfikator: @category.Id</p>
                <a class="button block" href="/quiz/@category.Id">Wybierz <span aria-hidden="true">→</span></a>
            </article>
        }
    </div>
}

@code {
    private List<CategoryDefinition> _categories = new();

    protected override async Task OnInitializedAsync()
    {
        _categories = await ProjectData.LoadCategoriesAsync(ProjectContext.CurrentProjectId);
    }

    private static string GetCategoryIcon(int index)
    {
        var icons = new[] { "①", "②", "③", "④", "⑤", "⑥", "⑦", "⑧" };
        return icons[index % icons.Length];
    }
}
