@page "/"
@inject ProjectCatalogService Catalog
@inject ProjectContextService ProjectContext
@inject NavigationManager Nav

<div class="card">
    <h1>Aplikacje Android</h1>
    <p class="muted">Wybierz projekt MVP. Każdy projekt korzysta ze wspólnego silnika, ale ma własne dane i własny styl.</p>
</div>

@foreach (var project in _projects)
{
    <div class="card">
        <h2>@project.Name</h2>
        <p>@project.Description</p>
        <button class="button" @onclick="() => SelectProject(project.Id)">Otwórz</button>
    </div>
}

<div class="card">
    <h3>Tryb MVP</h3>
    <p>Na tym etapie używamy lokalnych reguł, lokalnych danych i mockowanych reklam.</p>
</div>

@code {
    private IReadOnlyList<ProjectCatalogItem> _projects = Array.Empty<ProjectCatalogItem>();

    protected override void OnInitialized()
    {
        _projects = Catalog.GetProjects();
    }

    private void SelectProject(string projectId)
    {
        ProjectContext.SelectProject(projectId);
        Nav.NavigateTo("/categories");
    }
}
