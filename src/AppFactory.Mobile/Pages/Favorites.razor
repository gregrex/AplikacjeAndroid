@page "/favorites"
@inject FavoritesService Favorites
@inject ProjectContextService ProjectContext
@inject ProjectUiProfileService UiProfiles
@inject NavigationManager Nav

<section class="hero-card">
    <div class="hero-icon" aria-hidden="true">♡</div>
    <p class="result-kicker">Twoje zapisane wybory</p>
    <h1>Ulubione</h1>
    <p>Najważniejsze instrukcje, plany i rekomendacje w jednym miejscu.</p>
</section>

@if (_entries.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">♡</div>
        <h2>Brak ulubionych</h2>
        <p class="muted">Dodaj wynik po zakończeniu quizu, aby pojawił się na tej liście.</p>
        <a class="button" href="/">Wybierz aplikację</a>
    </div>
}
else
{
    <div class="section-heading">
        <div>
            <p class="result-kicker">Zapisane wyniki</p>
            <h2>@_entries.Count pozycji</h2>
        </div>
        <button class="button ghost" @onclick="ClearFavorites">Wyczyść ulubione</button>
    </div>

    <div class="project-grid">
        @foreach (var entry in _entries.OrderByDescending(x => x.CreatedAt))
        {
            var profile = UiProfiles.GetProfile(entry.ProjectId);
            <article class="project-card">
                <div class="project-icon" aria-hidden="true">@profile.Icon</div>
                <p class="result-kicker">@profile.Badge</p>
                <h3>@entry.ProjectId</h3>
                <p class="muted small">Wynik: @entry.ResultId</p>
                <p class="muted small">@entry.CreatedAt.ToLocalTime().ToString("g")</p>
                @if (CanOpen(entry))
                {
                    <button class="button block" @onclick="() => Open(entry)">Otwórz zapisany wynik</button>
                }
                else
                {
                    <span class="muted small">Starszy wpis bez kompletnej trasy wyniku.</span>
                }
                <button class="button ghost block" @onclick="() => Remove(entry.Id)">Usuń z ulubionych</button>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyList<FavoriteEntry> _entries = Array.Empty<FavoriteEntry>();

    protected override async Task OnInitializedAsync()
    {
        _entries = await Favorites.GetAllAsync();
    }

    private static bool CanOpen(FavoriteEntry entry) =>
        !string.IsNullOrWhiteSpace(entry.ProjectId)
        && !string.IsNullOrWhiteSpace(entry.CategoryId)
        && (!string.IsNullOrWhiteSpace(entry.FreeResultId) || !string.IsNullOrWhiteSpace(entry.ResultId));

    private void Open(FavoriteEntry entry)
    {
        ProjectContext.SelectProject(entry.ProjectId);
        var freeId = string.IsNullOrWhiteSpace(entry.FreeResultId) ? entry.ResultId : entry.FreeResultId;
        var premiumId = string.IsNullOrWhiteSpace(entry.PremiumResultId) ? entry.ResultId : entry.PremiumResultId;
        Nav.NavigateTo($"/result/{entry.CategoryId}/{freeId}/{premiumId}");
    }

    private async Task Remove(string entryId)
    {
        await Favorites.RemoveAsync(entryId);
        _entries = await Favorites.GetAllAsync();
    }

    private async Task ClearFavorites()
    {
        await Favorites.ClearAsync();
        _entries = Array.Empty<FavoriteEntry>();
    }
}
