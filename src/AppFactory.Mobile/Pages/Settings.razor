@page "/settings"
@inject LanguageService Language

<h1>Ustawienia</h1>

<div class="card">
    <h3>Język</h3>
    <p>Aktywny język: <strong>@Language.CurrentLanguage</strong></p>

    <div>
        @foreach (var language in Language.GetSupportedLanguages())
        {
            <p>
                <button class="button" @onclick="() => SetLanguage(language.Code)">
                    @language.NativeName (@language.Code)
                </button>
            </p>
        }
    </div>

    <p class="muted">Lista obejmuje języki krajów Unii Europejskiej oraz ukraiński. Jeżeli pełne tłumaczenie wyników nie istnieje, aplikacja użyje fallbacku do EN, a potem PL.</p>
</div>

<div class="card">
    <h3>Prywatność</h3>
    <p>Aplikacja działa lokalnie bez własnego serwera. Dane użytkownika w MVP są przechowywane tylko lokalnie.</p>
</div>

@code {
    private void SetLanguage(string language)
    {
        Language.SetLanguage(language);
    }
}
