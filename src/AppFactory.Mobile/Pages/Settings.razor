@page "/settings"
@using AppFactory.Persistence
@inject LanguageService Language
@inject LocalAiModelCatalogService ModelCatalog
@inject LocalAiModelStore ModelStore
@inject LocalDatabaseService Database
@inject AppFeatureFlags Features

<section class="hero-card">
    <div class="hero-icon" aria-hidden="true">⚙</div>
    <p class="result-kicker">Konfiguracja urządzenia</p>
    <h1>Ustawienia</h1>
    <p>Język wyników, dane lokalne, diagnostyka, prywatność i pomoc.</p>
</section>

<section class="card">
    <div class="section-heading">
        <div>
            <p class="result-kicker">Język</p>
            <h2>Aktywny: @Language.CurrentLanguage.ToUpperInvariant()</h2>
        </div>
        <span aria-hidden="true">🌐</span>
    </div>

    <div class="chip-row">
        @foreach (var language in Language.GetSupportedLanguages())
        {
            <button class="button @(Language.CurrentLanguage == language.Code ? string.Empty : "ghost")" @onclick="() => SetLanguage(language.Code)">
                @language.NativeName
            </button>
        }
    </div>

    <p class="muted small">Pełne wyniki są obecnie dostępne w PL, EN i UK. Dla pozostałych ustawień aplikacja używa jawnego fallbacku do EN, a następnie PL.</p>
</section>

<section class="card">
    <div class="section-heading">
        <div>
            <p class="result-kicker">Lokalna baza</p>
            <h2>SQLite na urządzeniu</h2>
        </div>
        <span aria-hidden="true">🗄️</span>
    </div>

    @if (_databaseHealth is null)
    {
        <p class="muted">Inicjalizacja bazy danych…</p>
    }
    else
    {
        <div class="metric-grid">
            <div class="metric">
                <span class="muted small">Stan</span>
                <strong>@(_databaseHealth.IsReady ? "Gotowa" : "Błąd")</strong>
            </div>
            <div class="metric">
                <span class="muted small">Schemat</span>
                <strong>v@_databaseHealth.SchemaVersion</strong>
            </div>
            <div class="metric">
                <span class="muted small">Historia</span>
                <strong>@_databaseHealth.HistoryCount</strong>
            </div>
            <div class="metric">
                <span class="muted small">Ulubione</span>
                <strong>@_databaseHealth.FavoritesCount</strong>
            </div>
        </div>
        <p class="muted small">Plik: @Path.GetFileName(_databaseHealth.DatabasePath)</p>
        <button class="button ghost" @onclick="RefreshDatabaseHealthAsync">Odśwież stan bazy</button>
    }

    @if (!string.IsNullOrWhiteSpace(_databaseMessage))
    {
        <p class="@(_databaseHealth?.IsReady == true ? "status-success" : "status-error")">@_databaseMessage</p>
    }
</section>

<section class="card">
    <div class="section-heading">
        <div>
            <p class="result-kicker">Diagnostyka</p>
            <h2>Logi lokalne i paczka ZIP</h2>
        </div>
        <span aria-hidden="true">🧾</span>
    </div>
    <p>Możesz samodzielnie sprawdzić stan danych i ręcznie wyeksportować logi, gdy zgłaszasz problem. Nic nie jest wysyłane automatycznie.</p>
    <a class="button block" href="/diagnostics">Otwórz logi i diagnostykę</a>
</section>

@if (Features.LocalAiEnabled)
{
    <section class="card">
        <div class="section-heading">
            <div>
                <p class="result-kicker">Local AI</p>
                <h2>Modele na telefonie</h2>
            </div>
            <span aria-hidden="true">◫</span>
        </div>
        <p>Modele są pobierane na urządzenie, weryfikowane przez SHA256 i używane lokalnie.</p>

        <div class="project-grid">
            @foreach (var model in _models)
            {
                var status = _statuses[model.ModelId];
                <article class="project-card">
                    <div class="project-icon" aria-hidden="true">@(model.Modality == "image" ? "🖼️" : "🎙️")</div>
                    <p class="result-kicker">@model.Modality</p>
                    <h3>@model.ModelId</h3>
                    <p class="muted small">Wersja @model.Version · @model.FileName</p>
                    <div class="chip-row">
                        <span class="chip">@(status.IsConfigured ? "Skonfigurowany" : "Brak konfiguracji")</span>
                        <span class="chip">@(status.IsVerified ? "Zweryfikowany" : "Niezweryfikowany")</span>
                    </div>
                    <p class="@(status.IsVerified ? "status-success" : "muted small")">@status.Message</p>
                    <button class="button block" disabled="@(!status.IsConfigured || _isDownloading)" @onclick="() => DownloadModel(model)">
                        @(status.IsDownloaded ? "Pobierz ponownie" : "Pobierz model")
                    </button>
                </article>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(_downloadMessage))
        {
            <div class="ai-result"><p>@_downloadMessage</p></div>
        }
    </section>
}

<section class="card">
    <div class="section-heading">
        <div>
            <p class="result-kicker">Prywatność i pomoc</p>
            <h2>Masz kontrolę nad danymi</h2>
        </div>
        <span aria-hidden="true">🔒</span>
    </div>
    <p>Historia, ulubione i logi pozostają na urządzeniu. Wersja sklepowa 1.0 nie zawiera reklam, kont użytkowników ani aktywnej analizy zdjęć i dźwięku.</p>
    <div class="action-grid">
        <a class="button" href="/privacy">Polityka prywatności</a>
        <a class="button ghost" href="/support">Pomoc i kontakt</a>
    </div>
</section>

@code {
    private IReadOnlyList<LocalAiModelProfile> _models = Array.Empty<LocalAiModelProfile>();
    private Dictionary<string, LocalAiModelStatus> _statuses = new(StringComparer.OrdinalIgnoreCase);
    private AppDatabaseHealth? _databaseHealth;
    private bool _isDownloading;
    private string _downloadMessage = string.Empty;
    private string _databaseMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Features.LocalAiEnabled)
        {
            RefreshModels();
        }
        await RefreshDatabaseHealthAsync();
    }

    private void SetLanguage(string language) => Language.SetLanguage(language);

    private async Task RefreshDatabaseHealthAsync()
    {
        try
        {
            _databaseHealth = await Database.GetHealthAsync();
            _databaseMessage = _databaseHealth.IsReady
                ? "Baza danych działa poprawnie."
                : "Baza danych nie zgłosiła poprawnej wersji schematu.";
        }
        catch (Exception ex)
        {
            _databaseHealth = null;
            _databaseMessage = $"Nie udało się zainicjalizować bazy: {ex.Message}";
        }
    }

    private async Task DownloadModel(LocalAiModelProfile model)
    {
        _isDownloading = true;
        _downloadMessage = $"Pobieram model {model.ModelId}...";
        try
        {
            var result = await ModelStore.DownloadAsync(model);
            _downloadMessage = result.Message;
            RefreshModels();
        }
        catch (Exception ex)
        {
            _downloadMessage = $"Pobieranie nie powiodło się: {ex.Message}";
        }
        finally
        {
            _isDownloading = false;
        }
    }

    private void RefreshModels()
    {
        _models = ModelCatalog.GetAll();
        _statuses = _models.ToDictionary(model => model.ModelId, ModelStore.GetStatus, StringComparer.OrdinalIgnoreCase);
    }
}
