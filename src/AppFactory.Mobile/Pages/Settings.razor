@page "/settings"
@inject LanguageService Language
@inject LocalAiModelCatalogService ModelCatalog
@inject LocalAiModelStore ModelStore

<section class="hero-card">
    <div class="hero-icon" aria-hidden="true">⚙</div>
    <p class="result-kicker">Konfiguracja urządzenia</p>
    <h1>Ustawienia</h1>
    <p>Język wyników, lokalne modele AI i informacje o prywatności.</p>
</section>

<section class="card">
    <div class="section-heading">
        <div>
            <p class="result-kicker">Język</p>
            <h2>Aktywny: @Language.CurrentLanguage.ToUpperInvariant()</h2>
        </div>
        <span aria-hidden="true">🌐</span>
    </div>

    <div class="chip-row">
        @foreach (var language in Language.GetSupportedLanguages())
        {
            <button class="button @(Language.CurrentLanguage == language.Code ? string.Empty : "ghost")" @onclick="() => SetLanguage(language.Code)">
                @language.NativeName
            </button>
        }
    </div>

    <p class="muted small">Pełne wyniki są obecnie dostępne w PL, EN i UK. Dla pozostałych ustawień aplikacja używa jawnego fallbacku do EN, a następnie PL.</p>
</section>

<section class="card">
    <div class="section-heading">
        <div>
            <p class="result-kicker">Local AI</p>
            <h2>Modele na telefonie</h2>
        </div>
        <span aria-hidden="true">◫</span>
    </div>
    <p>Modele są pobierane na urządzenie, weryfikowane przez SHA256 i używane lokalnie. Brak poprawnego URL lub sumy kontrolnej blokuje pobieranie.</p>

    <div class="project-grid">
        @foreach (var model in _models)
        {
            var status = _statuses[model.ModelId];
            <article class="project-card">
                <div class="project-icon" aria-hidden="true">@(model.Modality == "image" ? "🖼️" : "🎙️")</div>
                <p class="result-kicker">@model.Modality</p>
                <h3>@model.ModelId</h3>
                <p class="muted small">Wersja @model.Version · @model.FileName</p>
                <div class="chip-row">
                    <span class="chip">@(status.IsConfigured ? "Skonfigurowany" : "Brak konfiguracji")</span>
                    <span class="chip">@(status.IsVerified ? "Zweryfikowany" : "Niezweryfikowany")</span>
                </div>
                <p class="@(status.IsVerified ? "status-success" : "muted small")">@status.Message</p>
                <button class="button block" disabled="@(!status.IsConfigured || _isDownloading)" @onclick="() => DownloadModel(model)">
                    @(status.IsDownloaded ? "Pobierz ponownie" : "Pobierz model")
                </button>
            </article>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_downloadMessage))
    {
        <div class="ai-result">
            <p>@_downloadMessage</p>
        </div>
    }
</section>

<section class="card">
    <div class="section-heading">
        <div>
            <p class="result-kicker">Prywatność</p>
            <h2>Dane pozostają lokalnie</h2>
        </div>
        <span aria-hidden="true">🔒</span>
    </div>
    <p>Historia, ulubione, narzędzia i pliki robocze są obsługiwane lokalnie. Panel AI korzysta z lokalnego pliku i lokalnego modelu ONNX.</p>
</section>

@code {
    private IReadOnlyList<LocalAiModelProfile> _models = Array.Empty<LocalAiModelProfile>();
    private Dictionary<string, LocalAiModelStatus> _statuses = new(StringComparer.OrdinalIgnoreCase);
    private bool _isDownloading;
    private string _downloadMessage = string.Empty;

    protected override void OnInitialized()
    {
        RefreshModels();
    }

    private void SetLanguage(string language)
    {
        Language.SetLanguage(language);
    }

    private async Task DownloadModel(LocalAiModelProfile model)
    {
        _isDownloading = true;
        _downloadMessage = $"Pobieram model {model.ModelId}...";

        try
        {
            var result = await ModelStore.DownloadAsync(model);
            _downloadMessage = result.Message;
            RefreshModels();
        }
        catch (Exception ex)
        {
            _downloadMessage = $"Pobieranie nie powiodło się: {ex.Message}";
        }
        finally
        {
            _isDownloading = false;
        }
    }

    private void RefreshModels()
    {
        _models = ModelCatalog.GetAll();
        _statuses = _models.ToDictionary(model => model.ModelId, ModelStore.GetStatus, StringComparer.OrdinalIgnoreCase);
    }
}
