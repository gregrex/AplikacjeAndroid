@page "/quiz/{CategoryId}"
@inject ProjectDataService ProjectData
@inject RuleEngineService RuleEngine
@inject ProjectContextService ProjectContext
@inject ProjectUiProfileService UiProfiles
@inject AiSuggestionStateService SuggestionState
@inject ResultNavigationStateService ResultNavigationState
@inject NavigationManager Nav

@{
    var profile = UiProfiles.GetProfile(ProjectContext.CurrentProjectId);
}

<section class="hero-card">
    <div class="hero-icon" aria-hidden="true">@profile.Icon</div>
    <p class="result-kicker">Krok 2 · @profile.Badge</p>
    <h1>@profile.QuizHeading</h1>
    <p>Wybierz odpowiedź najlepiej opisującą sytuację. Możesz wrócić do poprzedniego pytania.</p>
</section>

@if (_questions.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">?</div>
        <h3>Brak pytań dla projektu</h3>
        <p class="muted">Pakiet danych nie zawiera pytań. Wróć do wyboru kategorii.</p>
        <a class="button" href="/categories">Wróć do kategorii</a>
    </div>
}
else if (_currentQuestion is not null)
{
    <section class="card">
        <div class="quiz-progress">
            <div class="section-heading">
                <p class="result-kicker">Pytanie @_displayQuestionNumber z @_questions.Count</p>
                <span class="muted small">@ProgressPercent%</span>
            </div>
            <div class="quiz-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@ProgressPercent">
                <div class="quiz-progress-value" style="width:@ProgressPercent%"></div>
            </div>
        </div>

        <h2>@_currentQuestion.TextKey</h2>

        @if (CurrentSuggestion is not null)
        {
            <div class="ai-result">
                <p class="result-kicker">Sugestia Local AI · @CurrentSuggestion.Source</p>
                <p><strong>@GetSuggestedOptionLabel(CurrentSuggestion.Value)</strong> · pewność @CurrentSuggestion.Confidence.ToString("P0")</p>
                @if (!string.IsNullOrWhiteSpace(CurrentSuggestion.Reason))
                {
                    <p class="muted small">@CurrentSuggestion.Reason</p>
                }
                <button class="button block" @onclick="UseSuggestion">Użyj tej sugestii</button>
                <p class="muted small">Odpowiedź trafi do quizu dopiero po kliknięciu tego przycisku.</p>
            </div>
        }

        <div class="answer-list">
            @for (var optionIndex = 0; optionIndex < _currentQuestion.Options.Count; optionIndex++)
            {
                var option = _currentQuestion.Options[optionIndex];
                <button class="answer-button" @onclick="() => SelectAnswer(option.Value)">
                    <span class="answer-index">@(optionIndex + 1)</span>
                    <span>@option.LabelKey</span>
                    <span class="answer-arrow" aria-hidden="true">›</span>
                </button>
            }
        </div>

        <div class="inline-actions" style="margin-top:16px">
            @if (_index > 0)
            {
                <button class="button ghost" @onclick="GoBack">← Poprzednie pytanie</button>
            }
            <button class="button ghost" @onclick="ResetQuiz">Zacznij od nowa</button>
        </div>
    </section>
}
else
{
    <section class="card">
        <div class="empty-state-icon" aria-hidden="true">✓</div>
        <p class="result-kicker">Odpowiedzi zebrane</p>
        <h2>Rekomendacja jest gotowa</h2>
        <p class="muted">Silnik reguł wybierze najlepsze dopasowanie i pokaże, dlaczego zostało wybrane.</p>
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <p class="status-error">@_errorMessage</p>
        }
        <div class="inline-actions">
            <button class="button" @onclick="ShowResult">Pokaż wynik</button>
            <button class="button ghost" @onclick="GoBack">Zmień ostatnią odpowiedź</button>
            <button class="button ghost" @onclick="ResetQuiz">Zacznij od nowa</button>
        </div>
    </section>
}

@code {
    [Parameter] public string CategoryId { get; set; } = string.Empty;

    private readonly List<UserAnswer> _answers = new();
    private List<QuestionDefinition> _questions = new();
    private List<RuleDefinition> _rules = new();
    private int _index;
    private string _errorMessage = string.Empty;
    private int _displayQuestionNumber => Math.Min(_index + 1, _questions.Count);
    private int ProgressPercent => _questions.Count == 0 ? 0 : (int)Math.Round((_displayQuestionNumber / (double)_questions.Count) * 100);
    private QuestionDefinition? _currentQuestion => _index < _questions.Count ? _questions[_index] : null;
    private AiSuggestedAnswer? CurrentSuggestion => _currentQuestion is null
        ? null
        : SuggestionState.GetForQuestion(ProjectContext.CurrentProjectId, _currentQuestion.Id);

    protected override async Task OnInitializedAsync()
    {
        _questions = await ProjectData.LoadQuestionsAsync(ProjectContext.CurrentProjectId);
        _rules = await ProjectData.LoadRulesAsync(ProjectContext.CurrentProjectId);
    }

    private void UseSuggestion()
    {
        if (CurrentSuggestion is null || _currentQuestion is null)
        {
            return;
        }

        var optionExists = _currentQuestion.Options.Any(x => string.Equals(x.Value, CurrentSuggestion.Value, StringComparison.OrdinalIgnoreCase));
        if (!optionExists)
        {
            _errorMessage = "Sugestia AI nie pasuje do opcji tego pytania i nie została użyta.";
            SuggestionState.Remove(ProjectContext.CurrentProjectId, _currentQuestion.Id);
            return;
        }

        SelectAnswer(CurrentSuggestion.Value);
    }

    private string GetSuggestedOptionLabel(string value) =>
        _currentQuestion?.Options.FirstOrDefault(x => string.Equals(x.Value, value, StringComparison.OrdinalIgnoreCase))?.LabelKey ?? value;

    private void SelectAnswer(string value)
    {
        if (_currentQuestion is null)
        {
            return;
        }

        var questionId = _currentQuestion.Id;
        _answers.RemoveAll(x => x.QuestionId == questionId);
        _answers.Add(new UserAnswer { QuestionId = questionId, Value = value });
        SuggestionState.Remove(ProjectContext.CurrentProjectId, questionId);
        _index++;
        _errorMessage = string.Empty;
    }

    private void GoBack()
    {
        if (_index <= 0)
        {
            return;
        }

        _index--;
        if (_currentQuestion is not null)
        {
            _answers.RemoveAll(x => x.QuestionId == _currentQuestion.Id);
        }
        _errorMessage = string.Empty;
    }

    private void ResetQuiz()
    {
        _answers.Clear();
        _index = 0;
        _errorMessage = string.Empty;
    }

    private void ShowResult()
    {
        var match = RuleEngine.Match(CategoryId, _answers, _rules);
        if (string.IsNullOrWhiteSpace(match.FreeResultId) || string.IsNullOrWhiteSpace(match.PremiumResultId))
        {
            _errorMessage = "Nie udało się znaleźć kompletnego wyniku. Wróć do kategorii albo sprawdź pakiet reguł projektu.";
            return;
        }

        SuggestionState.Clear(ProjectContext.CurrentProjectId);
        ResultNavigationState.Store(ProjectContext.CurrentProjectId, CategoryId, match.FreeResultId, match.PremiumResultId, match);
        Nav.NavigateTo($"/result/{CategoryId}/{match.FreeResultId}/{match.PremiumResultId}");
    }
}
